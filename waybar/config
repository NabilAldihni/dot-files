{
        "layer": "top",
        "position": "top",
        "reload_style_on_change": true,
        "modules-left": ["clock"],
        "modules-center": ["hyprland/workspaces"],
        "modules-right": ["group/expand","tray","custom/endpoint","pulseaudio","custom/tailscale-controls","network","battery","custom/notification"],


        "hyprland/workspaces": {
            "format": "{icon}",
            "format-icons": {
                "active": "",
                "default": "",
                "empty": ""
            },
            "persistent-workspaces": {
                "*": [ 1,2,3,4,5 ]
            }
        },
        "custom/notification": {
            "tooltip": false,
            "format": "",
            "on-click": "swaync-client -t -sw",
            "escape": true
        },
        "clock": {
            "format": "{:%H:%M - %d/%m/%Y} ",
            "tooltip-format": "<tt>{calendar}</tt>",
            "calendar": {
                "format": {
                    "today": "<span color='#45d4ff'><b>{}</b></span>",
                }
            },
            "actions": {
                "on-click-right": "shift_down",
                "on-click": "shift_up"
            }
        },
        "tray": {
            "spacing": 10,
            "show-passive-items": true,
            "reverse-direction": true,
        },
        "network": {
            "format-wifi": "",
            "format-ethernet":"",
            "format-disconnected": "",
            "tooltip-format-disconnected": "Error",
            "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
            "tooltip-format-ethernet": "{ifname} 🖧 ",
            "on-click": "alacritty -e nmtui"
        },
        "custom/tailscale-controls": {
            "exec": "~/.config/waybar/scripts/tailscale-controls.sh",
            "interval": 5,
            "return-type": "json",
            "on-click": "~/.config/waybar/scripts/tailscale-controls.sh toggle"
        },
        "pulseaudio": {
            "format": "  {volume}%",
            "format-bluetooth": " {volume}%",
            "format-muted": "  {volume}%",
            "scroll-step": 0,
            "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
            "ignored-sinks": ["Easy Effects Sink"]
        },
        "battery": {
            "interval":30,
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% 󰂄",
            "format-alt": "{time} {icon}",
            "format-icons": [
                "󰁻",
                "󰁼",
                "󰁾",
                "󰂀",
                "󰂂",
                "󰁹"
            ],
        },
        "custom/expand": {
            "format": "",
            "tooltip": false
        },
        "custom/endpoint":{
            "format": "|",
            "tooltip": false
        },
        "group/expand": {
            "orientation": "horizontal",
            "drawer": {
                "transition-duration": 600,
                "transition-to-left": true,
            },
            "modules": ["custom/expand", "custom/colorpicker","cpu","memory","temperature","disk","custom/endpoint"],
        },
        "custom/colorpicker": {
            "format": "{}",
            "return-type": "json",
            "interval": "once",
            "exec": "~/.config/waybar/scripts/colorpicker.sh -j",
            "on-click": "~/.config/waybar/scripts/colorpicker.sh",
            "signal": 1
        },
        "cpu": {
            "format": "󰻠",
            "tooltip": true
        },
        "memory": {
            "format": ""
        },
        "temperature": {
            "thermal-zone": 2,
            "critical-threshold": 80,
            "format": "",
        },
        "disk": {
            "interval": 60,
            "format": "",
            "tooltip-format": "Used {used} out of {total}",
            "path": "/"
        }
} 
